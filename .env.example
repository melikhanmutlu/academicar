# Flask
APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-string

# Database. Leave empty locally for SQLite; Railway PostgreSQL provides this.
DATABASE_URL=

# Public URL used by OAuth callbacks and generated QR/viewer links.
# Railway can also provide RAILWAY_PUBLIC_DOMAIN automatically.
SITE_URL=http://localhost:5000

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upload limits
MAX_CONTENT_LENGTH=52428800
UPLOAD_RATE_LIMIT_COUNT=5
UPLOAD_RATE_LIMIT_WINDOW=600

# Runtime folders. Railway filesystem is ephemeral; use external storage
# before relying on these for long-lived production files.
UPLOAD_FOLDER=uploads
CONVERTED_FOLDER=converted
QR_FOLDER=qr_codes
PDF_FOLDER=pdfs
