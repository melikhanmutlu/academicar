# Application Setup
APP_ENV=development
FLASK_DEBUG=1
SECRET_KEY=generate_a_secure_random_key_here

# Database Configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/academic_ar
DATABASE_URL=

# Redis (production/shared rate limits; optional locally)
REDIS_URL=redis://localhost:6379/0
# Local development can leave this as memory://. Railway/production should set it to REDIS_URL.
RATELIMIT_STORAGE_URI=memory://

# Storage Provider Configurations
STORAGE_PROVIDER=railway_volume

# File Directories (Relative to app root or absolute)
UPLOAD_FOLDER=uploads
CONVERTED_FOLDER=converted
QR_FOLDER=qr_codes
PDF_FOLDER=pdfs
# In Railway, attach a Volume and set STORAGE_ROOT to its mount path
# (or rely on RAILWAY_VOLUME_MOUNT_PATH when available).
STORAGE_ROOT=storage

# Upload Limits (in bytes)
MAX_CONTENT_LENGTH=272629760

# Local development can process conversion jobs inline so uploads appear immediately.
# Railway/production ignores DEV_INLINE_JOBS by default; run worker.py separately.
# Only set ALLOW_PRODUCTION_INLINE_JOBS=1 for emergency single-process debugging.
DEV_INLINE_JOBS=1

# Rate Limiting
UPLOAD_RATE_LIMIT_COUNT=5
UPLOAD_RATE_LIMIT_WINDOW=600

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# Custom Domains / Routing
SITE_URL=http://localhost:5000
