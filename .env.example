# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development
FLASK_DEBUG=1

# Database (boşsa SQLite kullanılır: instance/academic_ar.db)
DATABASE_URL=

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upload limitleri
MAX_CONTENT_LENGTH=52428800

# Klasör yolları (varsayılan değerler kullanılabilir)
UPLOAD_FOLDER=uploads
CONVERTED_FOLDER=converted
QR_FOLDER=qr_codes

# OAuth callback için site URL'i (production'da https://domain.com)
SITE_URL=http://localhost:5000
